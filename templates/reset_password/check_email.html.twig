{% extends 'base_auth.html.twig' %}

{% block title %}Email envoyé - LarryPDF{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto">

        {# ── Logo ── #}
        <div class="text-center mb-10">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 no-underline">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" class="h-12 w-auto">
                <span class="text-white text-2xl font-bold">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card text-center">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-larry/25 to-blue-500/25 border border-violet-larry/30 inline-flex items-center justify-center mb-5">
                <i class="fa-solid fa-envelope-circle-check text-violet-larry text-xl"></i>
            </div>
            <h1 class="text-white text-2xl font-bold mb-3">Email envoyé</h1>
            <p class="text-white/50 text-sm leading-relaxed mb-5">
                Si un compte correspond à votre adresse email, un lien de réinitialisation vient d'être envoyé.
                Ce lien expirera dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
            <p class="text-white/35 text-xs leading-relaxed">
                Vous n'avez pas reçu d'email ? Vérifiez vos spams ou
                <a href="{{ path('app_forgot_password_request') }}" class="text-violet-larry hover:underline">réessayez</a>.
            </p>
        </div>

        <p class="text-center text-white/40 text-sm mt-7">
            <a href="{{ path('app_login') }}" class="text-violet-larry hover:text-white transition font-medium">
                <i class="fa-solid fa-arrow-left text-xs mr-1"></i>Retour à la connexion
            </a>
        </p>
    </div>
{% endblock %}
