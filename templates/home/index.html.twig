{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<div class="flex items-center justify-center mx-auto max-w-3/4 gap-16">
    <div class="flex-1 flex flex-col gap-6">
        <h1 class="text-white text-6xl font-bold leading-tight">Convertissez vos PDFs<br>
            <span class="text-violet-larry">en quelques secondes</span>
        </h1>
        <p class="text-stone-300 text-lg max-w-xl">Plateforme professionnelle de conversion et création de PDF. Rapide, sécurisé et sans limite.</p>
        <div class="flex items-center gap-4 mt-2">
            <a href="#" class="text-black bg-[#F8F4F4] px-6 py-3 rounded-2xl transition text-base font-medium hover:bg-white">Commencer gratuitement</a>
            <a href="#" class="btn-larry-1">
                <span>Partager</span>
            </a>
        </div>
    </div>
    <div class="flex-1 flex justify-end">
        <img class="h-114 w-auto" src="{{ asset('images/ImageHeroSection.png') }}" alt="Image d'illustration">
    </div>
</div>
<div>
    <div class="flex items-center justify-center mx-auto max-w-3/4 gap-16">
        <div class="flex gap-24">
            <img class="h-92 w-auto" src="{{ asset('images/Personnage1.png') }}" alt="Image d'illustration">
            <div class="flex flex-col justify-center gap-6">
                <h2 class="text-white text-center text-4xl font-bold">Choisissez votre formule</h2>
                <p class="text-stone-300 text-lg">Des tarifs pour tous types de portefeuilles, adaptés à tous vos besoins.</p>
            </div>
        </div>
    </div>
    <div class="flex justify-center gap-18">
    {% for plan in plans %}
        {% if plan.name == 'BASIC' %}
        <div class="relative scale-120 bg-violet-larry/5 backdrop-blur-md rounded-lg border border-violet-larry/40 p-8">
            {% else %}
            <div class="relative bg-white/5 backdrop-blur-md rounded-lg border border-white/15 p-8">
                {% endif %}
                {% if plan.name == 'BASIC' %}
                <span class="absolute -top-4 -right-2 bg-white text-black text-xs font-semibold px-4 py-2 rounded-full">
                    Le plus populaire
                </span>
            {% endif %}
            <h3 class="text-white">{{ plan.name }}</h3>
            <p class="text-white">{{ plan.description }}</p>
            <p class="text-white text-4xl font-bold">{{ plan.price }} € <span class="text-stone-300 text-base">/mois</span> </p>
                <a href="#" class="btn-larry-1">
                    <span>Partager</span>
                </a>
        </div>
    {% endfor %}
    </div>
</div>

{% endblock %}
