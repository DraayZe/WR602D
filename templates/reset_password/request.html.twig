{% extends 'base_auth.html.twig' %}

{% block title %}Mot de passe oublié - LarryPDF{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto">

        {# ── Logo ── #}
        <div class="text-center mb-10">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 no-underline">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" class="h-12 w-auto">
                <span class="text-white text-2xl font-bold">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card">
            <div class="text-center mb-6">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-larry/25 to-blue-500/25 border border-violet-larry/30 inline-flex items-center justify-center mb-4">
                    <i class="fa-solid fa-key text-violet-larry text-xl"></i>
                </div>
                <h1 class="text-white text-2xl font-bold mb-1">Mot de passe oublié</h1>
                <p class="text-white/40 text-sm">Entrez votre email pour recevoir un lien de réinitialisation</p>
            </div>

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="flex items-center gap-2 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm mb-6">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>{{ flash_error }}</span>
                </div>
            {% endfor %}

            {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-7">
                    <label for="{{ requestForm.email.vars.id }}" class="block text-white/60 text-sm font-medium mb-2">Adresse email</label>
                    <div class="auth-icon-wrap relative">
                        <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-white/20 text-sm pointer-events-none z-2"></i>
                        {{ form_widget(requestForm.email, {'attr': {'class': 'auth-input', 'placeholder': 'exemple@email.com'}}) }}
                    </div>
                    <div class="text-red-400 text-xs mt-1">{{ form_errors(requestForm.email) }}</div>
                </div>

                <button type="submit" class="auth-submit">
                    <span>Envoyer le lien</span>
                </button>

            {{ form_end(requestForm) }}
        </div>

        <p class="text-center text-white/40 text-sm mt-7">
            <a href="{{ path('app_login') }}" class="text-violet-larry hover:text-white transition font-medium">
                <i class="fa-solid fa-arrow-left text-xs mr-1"></i>Retour à la connexion
            </a>
        </p>
    </div>
{% endblock %}
