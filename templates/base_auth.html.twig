<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}LarryPDF{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>&#x26AB;&#xFE0F;</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <style>
            /* ── Auth base styles (inline to guarantee rendering) ── */
            .auth-page {
                min-height: 100vh;
                background-color: #0a0118;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
                overflow: hidden;
                padding: 2rem 1rem;
            }
            .auth-bg-violet {
                position: absolute;
                top: -20%;
                left: -10%;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(177,85,255,0.18) 0%, transparent 70%);
                pointer-events: none;
                z-index: 0;
            }
            .auth-bg-blue {
                position: absolute;
                bottom: -20%;
                right: -10%;
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(80,120,255,0.12) 0%, transparent 70%);
                pointer-events: none;
                z-index: 0;
            }
            .auth-card {
                background: rgba(255, 255, 255, 0.04);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 1.25rem;
                padding: 2.5rem;
                box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.05);
                position: relative;
                z-index: 1;
            }
            .auth-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60%;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(177,85,255,0.4), transparent);
            }

            /* ── Inputs ── */
            .auth-field input[type="text"],
            .auth-field input[type="email"],
            .auth-field input[type="password"],
            .auth-field input[type="tel"],
            .auth-field input[type="number"],
            .auth-field input[type="date"] {
                width: 100%;
                background: rgba(255, 255, 255, 0.04);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 0.75rem;
                padding: 0.75rem 1rem 0.75rem 2.75rem;
                color: #ffffff;
                font-size: 0.875rem;
                outline: none;
                transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            }
            .auth-field input::placeholder {
                color: rgba(255,255,255,0.25);
            }
            .auth-field input:focus {
                border-color: rgba(177, 85, 255, 0.5);
                background: rgba(255, 255, 255, 0.07);
                box-shadow: 0 0 0 3px rgba(177, 85, 255, 0.08), 0 0 20px rgba(177,85,255,0.06);
            }

            /* ── Date input calendar icon ── */
            .auth-field input[type="date"]::-webkit-calendar-picker-indicator {
                filter: invert(1) brightness(0.7);
                cursor: pointer;
            }
            .auth-field input[type="date"] {
                color-scheme: dark;
            }

            /* ── Autocomplete override ── */
            .auth-field input:-webkit-autofill,
            .auth-field input:-webkit-autofill:hover,
            .auth-field input:-webkit-autofill:focus {
                -webkit-text-fill-color: #ffffff;
                -webkit-box-shadow: 0 0 0 1000px rgba(30, 15, 50, 0.99) inset;
                box-shadow: 0 0 0 1000px rgba(30, 15, 50, 0.99) inset;
                border-color: rgba(177, 85, 255, 0.3);
                caret-color: #ffffff;
                transition: background-color 5000s ease-in-out 0s;
            }

            /* ── Icon change when input filled ── */
            .auth-icon-wrap.has-value i {
                color: #B155FF;
            }

            /* ── Selects (date fields) ── */
            .auth-field select {
                background: rgba(255, 255, 255, 0.04) !important;
                border: 1px solid rgba(255, 255, 255, 0.1) !important;
                border-radius: 0.75rem;
                padding: 0.75rem 0.5rem;
                color: #ffffff !important;
                font-size: 0.8rem;
                outline: none;
                transition: border-color 0.2s, background 0.2s;
                width: 100%;
                -webkit-appearance: none;
                appearance: none;
            }
            .auth-field select:focus {
                border-color: rgba(177, 85, 255, 0.5) !important;
                background: rgba(255, 255, 255, 0.07) !important;
            }
            .auth-field select option {
                background: #1a0e2e;
                color: #fff;
            }

            /* ── Date row: Symfony wraps selects in a div ── */
            .auth-date-row,
            .auth-date-row > div {
                display: flex;
                gap: 0.5rem;
            }
            .auth-date-row > div > select {
                flex: 1;
            }

            /* ── Labels ── */
            .auth-field-label {
                display: block;
                color: rgba(255,255,255,0.6);
                font-size: 0.8rem;
                font-weight: 500;
                margin-bottom: 0.5rem;
                letter-spacing: 0.02em;
            }

            /* ── Input icon ── */
            .auth-icon-wrap {
                position: relative;
            }
            .auth-icon-wrap i {
                position: absolute;
                left: 0.9rem;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255,255,255,0.2);
                font-size: 0.85rem;
                pointer-events: none;
                z-index: 2;
            }

            /* ── Date row (3 selects side by side) ── */
            .auth-date-row {
                display: flex;
                gap: 0.5rem;
            }
            .auth-date-row select {
                flex: 1;
            }

            /* ── Checkbox ── */
            .auth-checkbox-row {
                display: flex;
                align-items: flex-start;
                gap: 0.75rem;
            }
            .auth-checkbox-row input[type="checkbox"] {
                width: 1.1rem;
                height: 1.1rem;
                accent-color: #B155FF;
                cursor: pointer;
                flex-shrink: 0;
                margin-top: 0.15rem;
                border-radius: 0.25rem;
            }
            .auth-checkbox-row label,
            .auth-checkbox-row span {
                color: rgba(255,255,255,0.45);
                font-size: 0.8rem;
                line-height: 1.5;
                cursor: pointer;
            }
            .auth-checkbox-row a {
                color: #B155FF;
                text-decoration: none;
            }
            .auth-checkbox-row a:hover {
                text-decoration: underline;
            }

            /* ── Submit button (matching btn-larry-1) ── */
            .auth-submit {
                width: 100%;
                padding: 2px;
                border-radius: 0.85rem;
                background: linear-gradient(to bottom, rgba(255,255,255,0.35), rgba(255,255,255,0.08));
                border: 1px solid rgba(255,255,255,0.8);
                box-shadow: 0 0 18px 3px rgba(100, 80, 200, 0.5);
                cursor: pointer;
                display: block;
                margin-top: 0.5rem;
                transition: box-shadow 0.3s;
            }
            .auth-submit:hover {
                box-shadow: 0 0 25px 5px rgba(130, 90, 230, 0.6);
            }
            .auth-submit span {
                display: block;
                width: 100%;
                padding: 0.8rem 0;
                font-size: 0.95rem;
                color: #fff;
                font-weight: 600;
                letter-spacing: 0.02em;
                border-radius: 0.75rem;
                background: linear-gradient(to bottom, #6b6b8d, #3b3260);
                text-align: center;
                transition: background 0.2s;
            }
            .auth-submit:hover span {
                background: linear-gradient(to bottom, #7d7d9f, #4a4170);
            }

            /* ── Error messages ── */
            .auth-flash-error {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                background: rgba(239, 68, 68, 0.08);
                border: 1px solid rgba(239, 68, 68, 0.18);
                border-radius: 0.75rem;
                padding: 0.7rem 1rem;
                color: #f87171;
                font-size: 0.82rem;
                margin-bottom: 1.5rem;
            }

            /* ── Hide Symfony generated labels inside auth-field ── */
            .auth-field > div > label,
            .auth-icon-wrap > label,
            .auth-date-row > label {
                display: none !important;
            }

            /* ── Symfony form errors ── */
            .auth-field .help-text,
            .auth-field ul {
                list-style: none;
                padding: 0;
                margin: 0.35rem 0 0 0;
            }
            .auth-field ul li,
            .auth-field .form-error-message {
                color: #f87171;
                font-size: 0.78rem;
            }

            /* ── Link style ── */
            .auth-link {
                color: #B155FF;
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s;
            }
            .auth-link:hover {
                color: #d4a0ff;
            }

            /* ── Fade in animation ── */
            .auth-fade-in {
                opacity: 0;
                transform: translateY(16px);
                animation: authFadeIn 0.5s ease forwards;
            }
            @keyframes authFadeIn {
                to { opacity: 1; transform: translateY(0); }
            }
        </style>
    </head>
    <body>
        <div class="auth-page">
            <div class="auth-bg-violet"></div>
            <div class="auth-bg-blue"></div>
            <img class="absolute top-0 left-0 z-0 pointer-events-none opacity-60" src="{{ asset('images/Ellipse1violet.png') }}" alt="">
            <img class="absolute top-0 right-0 z-0 pointer-events-none opacity-60" src="{{ asset('images/Ellipse2bleu.png') }}" alt="">

            <div class="auth-fade-in" style="position:relative; z-index:1; width:100%;">
                {% block body %}{% endblock %}
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                function checkInputs() {
                    document.querySelectorAll('.auth-icon-wrap').forEach(function(wrap) {
                        var input = wrap.querySelector('input');
                        if (input) {
                            if (input.value.length > 0) {
                                wrap.classList.add('has-value');
                            } else {
                                wrap.classList.remove('has-value');
                            }
                        }
                    });
                }
                checkInputs();
                document.addEventListener('input', checkInputs);
                // Handle browser autofill with a short delay
                setTimeout(checkInputs, 200);
                setTimeout(checkInputs, 1000);
            });
        </script>
    </body>
</html>
