{% extends 'base_auth.html.twig' %}

{% block title %}Mot de passe oublié - LarryPDF{% endblock %}

{% block body %}
    <div style="max-width: 420px; margin: 0 auto;">

        {# ── Logo ── #}
        <div style="text-align:center; margin-bottom: 2.5rem;">
            <a href="{{ path('app_home') }}" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" style="height:48px; width:auto;">
                <span style="color:#fff; font-size:1.6rem; font-weight:700;">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card">
            <div style="text-align:center; margin-bottom:1.5rem;">
                <div style="width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg, rgba(177,85,255,0.25), rgba(80,120,255,0.25)); border:1px solid rgba(177,85,255,0.3); display:inline-flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                    <i class="fa-solid fa-key" style="color:#B155FF; font-size:1.3rem;"></i>
                </div>
                <h1 style="color:#fff; font-size:1.5rem; font-weight:700; margin:0 0 0.3rem 0;">Mot de passe oublié</h1>
                <p style="color:rgba(255,255,255,0.4); font-size:0.85rem; margin:0;">Entrez votre email pour recevoir un lien de réinitialisation</p>
            </div>

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="auth-flash-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>{{ flash_error }}</span>
                </div>
            {% endfor %}

            {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="auth-field" style="margin-bottom:1.75rem;">
                    <label class="auth-field-label" for="{{ requestForm.email.vars.id }}">Adresse email</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-envelope"></i>
                        {{ form_widget(requestForm.email, {'attr': {
                            'placeholder': 'exemple@email.com'
                        }}) }}
                    </div>
                    {{ form_errors(requestForm.email) }}
                </div>

                <button type="submit" class="auth-submit">
                    <span>Envoyer le lien</span>
                </button>

            {{ form_end(requestForm) }}
        </div>

        <p style="text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:1.75rem;">
            <a href="{{ path('app_login') }}" class="auth-link"><i class="fa-solid fa-arrow-left" style="font-size:0.75rem; margin-right:0.4rem;"></i>Retour à la connexion</a>
        </p>
    </div>
{% endblock %}
