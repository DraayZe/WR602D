{% extends 'base_auth.html.twig' %}

{% block title %}Inscription - LarryPDF{% endblock %}

{% block body %}
    <div style="max-width: 520px; margin: 0 auto;">

        {# ── Logo ── #}
        <div style="text-align:center; margin-bottom: 2.5rem;">
            <a href="{{ path('app_home') }}" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" style="height:48px; width:auto;">
                <span style="color:#fff; font-size:1.6rem; font-weight:700;">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card">
            <h1 style="color:#fff; font-size:1.5rem; font-weight:700; text-align:center; margin:0 0 0.3rem 0;">Créer un compte</h1>
            <p style="color:rgba(255,255,255,0.4); font-size:0.85rem; text-align:center; margin:0 0 2rem 0;">Rejoignez LarryPDF gratuitement</p>

            {# ── Flash errors ── #}
            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="auth-flash-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>{{ flash_error }}</span>
                </div>
            {% endfor %}

            {% if registrationForm.vars.errors|length > 0 %}
                <div class="auth-flash-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>{{ form_errors(registrationForm) }}</span>
                </div>
            {% endif %}

            {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

                {# ── Nom / Prénom (2 cols) ── #}
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.25rem;">
                    <div class="auth-field">
                        <label class="auth-field-label" for="{{ registrationForm.lastname.vars.id }}">Nom</label>
                        <div class="auth-icon-wrap">
                            <i class="fa-solid fa-user"></i>
                            {{ form_widget(registrationForm.lastname, {'attr': {
                                'placeholder': 'Dupont'
                            }}) }}
                        </div>
                        {{ form_errors(registrationForm.lastname) }}
                    </div>
                    <div class="auth-field">
                        <label class="auth-field-label" for="{{ registrationForm.firstname.vars.id }}">Prénom</label>
                        <div class="auth-icon-wrap">
                            <i class="fa-solid fa-user"></i>
                            {{ form_widget(registrationForm.firstname, {'attr': {
                                'placeholder': 'Jean'
                            }}) }}
                        </div>
                        {{ form_errors(registrationForm.firstname) }}
                    </div>
                </div>

                {# ── Email ── #}
                <div class="auth-field" style="margin-bottom:1.25rem;">
                    <label class="auth-field-label" for="{{ registrationForm.email.vars.id }}">Adresse email</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-envelope"></i>
                        {{ form_widget(registrationForm.email, {'attr': {
                            'placeholder': 'exemple@email.com'
                        }}) }}
                    </div>
                    {{ form_errors(registrationForm.email) }}
                </div>

                {# ── Mot de passe ── #}
                <div class="auth-field" style="margin-bottom:1.25rem;">
                    <label class="auth-field-label" for="{{ registrationForm.plainPassword.vars.id }}">Mot de passe</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-lock"></i>
                        {{ form_widget(registrationForm.plainPassword, {'attr': {
                            'placeholder': 'Minimum 6 caractères'
                        }}) }}
                    </div>
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                {# ── Date de naissance / Téléphone (2 cols) ── #}
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.25rem;">
                    <div class="auth-field">
                        <label class="auth-field-label" for="{{ registrationForm.dob.vars.id }}">Date de naissance</label>
                        <div class="auth-date-row">
                            {{ form_widget(registrationForm.dob) }}
                        </div>
                        {{ form_errors(registrationForm.dob) }}
                    </div>
                    <div class="auth-field">
                        <label class="auth-field-label" for="{{ registrationForm.phone.vars.id }}">Téléphone</label>
                        <div class="auth-icon-wrap">
                            <i class="fa-solid fa-phone"></i>
                            {{ form_widget(registrationForm.phone, {'attr': {
                                'placeholder': '06 12 34 56 78'
                            }}) }}
                        </div>
                        {{ form_errors(registrationForm.phone) }}
                    </div>
                </div>

                {# ── Couleur préférée ── #}
                <div class="auth-field" style="margin-bottom:1.5rem;">
                    <label class="auth-field-label" for="{{ registrationForm.favoriteColor.vars.id }}">Couleur préférée</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-palette"></i>
                        {{ form_widget(registrationForm.favoriteColor, {'attr': {
                            'placeholder': 'Violet, Bleu...'
                        }}) }}
                    </div>
                    {{ form_errors(registrationForm.favoriteColor) }}
                </div>

                {# ── Checkbox CGU ── #}
                <div class="auth-checkbox-row" style="margin-bottom:1.5rem;">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label for="{{ registrationForm.agreeTerms.vars.id }}">
                        J'accepte les <a href="#">conditions d'utilisation</a>
                        et la <a href="#">politique de confidentialité</a>
                    </label>
                </div>
                {{ form_errors(registrationForm.agreeTerms) }}

                {# ── Submit ── #}
                <button type="submit" class="auth-submit">
                    <span>Créer mon compte</span>
                </button>

            {{ form_end(registrationForm) }}
        </div>

        {# ── Footer link ── #}
        <p style="text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:1.75rem;">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="auth-link">Se connecter</a>
        </p>
    </div>
{% endblock %}
