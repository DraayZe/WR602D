<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-[#0a0118] relative overflow-x-hidden">
        <img class="absolute top-0 left-0 z-0" src="{{ asset('images/Ellipse1violet.png') }}">
        <img class="absolute top-0 right-0 z-0" src="{{ asset('images/Ellipse2bleu.png') }}">

        <header class="relative z-10 pt-6">
            {% block nav %}
                <nav class="mx-auto max-w-3/4 flex items-center justify-between px-6 py-3 bg-white/5 backdrop-blur-md rounded-2xl border border-white/15">
                    <div class="flex items-center gap-1">
                        <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" class="h-auto w-18">
                        <span class="text-white text-2xl font-bold">LarryPDF</span>
                    </div>

                    <div class="flex items-center gap-8">
                        <a href="#" class="text-stone-300 hover:text-white transition text-base">Outils</a>
                        <a href="#" class="text-stone-300 hover:text-white transition text-base">Tarifs</a>
                        <a href="#" class="text-stone-300 hover:text-white transition text-base">Conversion</a>
                        <a href="#" class="text-stone-300 hover:text-white transition text-base">Historique</a>
                    </div>

                    <div class="flex items-center gap-4">
                        {% if app.user %}
                            <div class="relative" id="profile-dropdown">
                                <button onclick="document.getElementById('profile-menu').classList.toggle('hidden')" class="flex items-center gap-2 bg-white/5 backdrop-blur-md rounded-full py-2 px-4 border border-white/10 hover:bg-white/10 transition cursor-pointer">
                                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-larry to-violet-larry-dark flex items-center justify-center">
                                        <i class="fa-solid fa-user text-white text-sm"></i>
                                    </div>
                                    <span class="text-white text-sm font-medium">{{ app.user.firstname }}</span>
                                    <i class="fa-solid fa-chevron-down text-stone-400 text-xs ml-1"></i>
                                </button>
                                <div id="profile-menu" class="hidden absolute right-0 mt-2 w-48 bg-white/5 backdrop-blur-xl rounded-xl border border-white/10 shadow-lg overflow-hidden z-50">
                                    <a href="{{ logout_path() }}" class="flex items-center gap-3 px-4 py-3 text-stone-300 hover:bg-white/10 hover:text-white transition text-sm">
                                        <i class="fa-solid fa-right-from-bracket text-xs"></i>
                                        Déconnexion
                                    </a>
                                </div>
                            </div>
                            <script>
                                document.addEventListener('click', function(e) {
                                    const dropdown = document.getElementById('profile-dropdown');
                                    const menu = document.getElementById('profile-menu');
                                    if (dropdown && !dropdown.contains(e.target)) {
                                        menu.classList.add('hidden');
                                    }
                                });
                            </script>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="text-stone-300 hover:text-white transition text-base">Connexion</a>
                            <a href="{{ path('app_register') }}" class="btn-larry-1">
                                <span>Démarrer</span>
                            </a>
                        {% endif %}
                    </div>
                </nav>
            {% endblock %}
        </header>

        <div class="absolute bottom-0 left-0 w-full z-[1] pointer-events-none">
            <img src="{{ asset('images/background-footer.png') }}" alt="" class="w-full object-cover">
        </div>

        <main class="relative z-10">
            {% block body %}{% endblock %}
        </main>

        <footer class="relative z-10 mt-24 backdrop-blur-lg border-white/20 border-t-1">
            <div class="mx-auto max-w-3/4 px-6 pt-16 ">

                <div class="grid grid-cols-4 gap-12 pb-12">
                    <div class="col-span-1">
                        <div class="flex items-center justify-start">
                            <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" class="h-auto w-18">
                            <span class="text-white text-xl font-bold">LarryPDF</span>
                        </div>
                        <p class="text-stone-400 text-sm leading-relaxed">
                            Plateforme professionnelle de conversion et création de PDF. Rapide, sécurisé et sans limite.
                        </p>
                        <div class="flex gap-2 mt-14 mb-8">
                            <div class="footer-bg-social-media">
                                <img src="{{ asset('images/icone_linkedin.png') }}" alt="Linkedin" class="h-6 w-6">
                            </div>
                            <div class="footer-bg-social-media">
                                <img src="{{ asset('images/icone_instagram.png') }}" alt="Instagram" class="h-6 w-6">
                            </div>
                            <div class="footer-bg-social-media">
                                <img src="{{ asset('images/icone_github.png') }}" alt="GitHub" class="h-6 w-6">
                            </div>
                            <div class="footer-bg-social-media">
                                <img src="{{ asset('images/icone_x.png') }}" alt="X" class="h-6 w-6">
                            </div>
                        </div>
                    </div>

                    <div>
                        <h4 class="text-white font-semibold text-sm mb-4 uppercase tracking-wider">Produit vers PDF</h4>
                        <ul class="flex flex-col gap-3">
                            <li><a href="#" class="footer-link">URL vers PDF</a></li>
                            <li><a href="#" class="footer-link">Page vers PDF</a></li>
                            <li><a href="#" class="footer-link">Word vers PDF</a></li>
                            <li><a href="#" class="footer-link">Division</a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="text-white font-semibold text-sm mb-4 uppercase tracking-wider">PDF vers produit</h4>
                        <ul class="flex flex-col gap-3">
                            <li><a href="#" class="footer-link">URL vers PDF</a></li>
                            <li><a href="#" class="footer-link">Page vers PDF</a></li>
                            <li><a href="#" class="footer-link">Word vers PDF</a></li>
                            <li><a href="#" class="footer-link">Division</a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="text-white font-semibold text-sm mb-4 uppercase tracking-wider">Ressources</h4>
                        <ul class="flex flex-col gap-3">
                            <li><a href="#" class="footer-link">FAQ</a></li>
                            <li><a href="#" class="footer-link">Contactez-nous</a></li>
                            <li><a href="#" class="footer-link">API</a></li>
                        </ul>
                    </div>

                </div>

                <div class="footer-divider"></div>

                <div class="flex items-center justify-between py-6">
                    <p class="text-stone-500 text-sm">&copy; 2026 LarryPDF. All rights reserved.</p>
                    <div class="flex items-center gap-6">
                        <a href="#" class="footer-link">Politique de confidentialité</a>
                        <a href="#" class="footer-link">Conditions d'utilisation</a>
                        <a href="#" class="footer-link">Paramètres des cookies</a>
                    </div>
                </div>
            </div>
        </footer>

    </body>
</html>
