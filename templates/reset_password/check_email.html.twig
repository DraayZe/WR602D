{% extends 'base_auth.html.twig' %}

{% block title %}Email envoyé - LarryPDF{% endblock %}

{% block body %}
    <div style="max-width: 420px; margin: 0 auto;">

        {# ── Logo ── #}
        <div style="text-align:center; margin-bottom: 2.5rem;">
            <a href="{{ path('app_home') }}" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" style="height:48px; width:auto;">
                <span style="color:#fff; font-size:1.6rem; font-weight:700;">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card" style="text-align:center;">
            <div style="width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg, rgba(177,85,255,0.25), rgba(80,120,255,0.25)); border:1px solid rgba(177,85,255,0.3); display:inline-flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
                <i class="fa-solid fa-envelope-circle-check" style="color:#B155FF; font-size:1.3rem;"></i>
            </div>
            <h1 style="color:#fff; font-size:1.5rem; font-weight:700; margin:0 0 0.75rem 0;">Email envoyé</h1>
            <p style="color:rgba(255,255,255,0.5); font-size:0.85rem; line-height:1.6; margin:0 0 1.25rem 0;">
                Si un compte correspond à votre adresse email, un lien de réinitialisation vient d'être envoyé.
                Ce lien expirera dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
            <p style="color:rgba(255,255,255,0.35); font-size:0.8rem; line-height:1.5; margin:0;">
                Vous n'avez pas reçu d'email ? Vérifiez vos spams ou
                <a href="{{ path('app_forgot_password_request') }}" class="auth-link">réessayez</a>.
            </p>
        </div>

        <p style="text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:1.75rem;">
            <a href="{{ path('app_login') }}" class="auth-link"><i class="fa-solid fa-arrow-left" style="font-size:0.75rem; margin-right:0.4rem;"></i>Retour à la connexion</a>
        </p>
    </div>
{% endblock %}
