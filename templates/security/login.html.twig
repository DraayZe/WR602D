{% extends 'base_auth.html.twig' %}

{% block title %}Connexion - LarryPDF{% endblock %}

{% block body %}
    <div style="max-width: 420px; margin: 0 auto;">

        {# ── Logo ── #}
        <div style="text-align:center; margin-bottom: 2.5rem;">
            <a href="{{ path('app_home') }}" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" style="height:48px; width:auto;">
                <span style="color:#fff; font-size:1.6rem; font-weight:700;">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card">
            <h1 style="color:#fff; font-size:1.5rem; font-weight:700; text-align:center; margin:0 0 0.3rem 0;">Connexion</h1>
            <p style="color:rgba(255,255,255,0.4); font-size:0.85rem; text-align:center; margin:0 0 2rem 0;">Accédez à votre espace LarryPDF</p>

            {% if error %}
                <div class="auth-flash-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {% if app.user %}
                <div style="color:rgba(255,255,255,0.5); font-size:0.85rem; text-align:center; margin-bottom:1.5rem;">
                    Connecté en tant que {{ app.user.userIdentifier }},
                    <a href="{{ logout_path() }}" class="auth-link">Se déconnecter</a>
                </div>
            {% endif %}

            <form method="post">
                {# ── Email ── #}
                <div class="auth-field" style="margin-bottom:1.25rem;">
                    <label class="auth-field-label" for="username">Adresse email</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-envelope"></i>
                        <input type="email" value="{{ last_username }}" name="_username" id="username"
                               placeholder="exemple@email.com"
                               autocomplete="email" required autofocus>
                    </div>
                </div>

                {# ── Password ── #}
                <div class="auth-field" style="margin-bottom:1.75rem;">
                    <label class="auth-field-label" for="password">Mot de passe</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" name="_password" id="password"
                               placeholder="Votre mot de passe"
                               autocomplete="current-password" required>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <div style="text-align:right; margin-bottom:1.25rem;">
                    <a href="{{ path('app_forgot_password_request') }}" class="auth-link" style="font-size:0.8rem;">Mot de passe oublié ?</a>
                </div>

                {# ── Submit ── #}
                <button type="submit" class="auth-submit">
                    <span>Se connecter</span>
                </button>
            </form>
        </div>

        {# ── Footer link ── #}
        <p style="text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:1.75rem;">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="auth-link">Créer un compte</a>
        </p>
    </div>
{% endblock %}
