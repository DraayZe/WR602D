{% extends 'base_auth.html.twig' %}

{% block title %}Nouveau mot de passe - LarryPDF{% endblock %}

{% block body %}
    <div style="max-width: 420px; margin: 0 auto;">

        {# ── Logo ── #}
        <div style="text-align:center; margin-bottom: 2.5rem;">
            <a href="{{ path('app_home') }}" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <img src="{{ asset('images/LogoLarryPDF.png') }}" alt="LarryPDF" style="height:48px; width:auto;">
                <span style="color:#fff; font-size:1.6rem; font-weight:700;">LarryPDF</span>
            </a>
        </div>

        {# ── Card ── #}
        <div class="auth-card">
            <div style="text-align:center; margin-bottom:1.5rem;">
                <div style="width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg, rgba(177,85,255,0.25), rgba(80,120,255,0.25)); border:1px solid rgba(177,85,255,0.3); display:inline-flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                    <i class="fa-solid fa-lock" style="color:#B155FF; font-size:1.3rem;"></i>
                </div>
                <h1 style="color:#fff; font-size:1.5rem; font-weight:700; margin:0 0 0.3rem 0;">Nouveau mot de passe</h1>
                <p style="color:rgba(255,255,255,0.4); font-size:0.85rem; margin:0;">Choisissez votre nouveau mot de passe</p>
            </div>

            {{ form_start(resetForm, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="auth-field" style="margin-bottom:1.25rem;">
                    <label class="auth-field-label" for="{{ resetForm.plainPassword.first.vars.id }}">Nouveau mot de passe</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-lock"></i>
                        {{ form_widget(resetForm.plainPassword.first, {'attr': {
                            'placeholder': 'Minimum 6 caractères'
                        }}) }}
                    </div>
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>

                <div class="auth-field" style="margin-bottom:1.75rem;">
                    <label class="auth-field-label" for="{{ resetForm.plainPassword.second.vars.id }}">Confirmer le mot de passe</label>
                    <div class="auth-icon-wrap">
                        <i class="fa-solid fa-lock"></i>
                        {{ form_widget(resetForm.plainPassword.second, {'attr': {
                            'placeholder': 'Retapez votre mot de passe'
                        }}) }}
                    </div>
                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>

                {{ form_errors(resetForm.plainPassword) }}

                <button type="submit" class="auth-submit">
                    <span>Réinitialiser le mot de passe</span>
                </button>

            {{ form_end(resetForm) }}
        </div>

        <p style="text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:1.75rem;">
            <a href="{{ path('app_login') }}" class="auth-link"><i class="fa-solid fa-arrow-left" style="font-size:0.75rem; margin-right:0.4rem;"></i>Retour à la connexion</a>
        </p>
    </div>
{% endblock %}
